# Cognitive Venture OS — 环境变量示例
#
# 复制为 .env.local 并填入实际值（.env.local 已经在 .gitignore 里）。
# 三种模式由 NEXT_PUBLIC_APP_MODE 决定：
#   demo       —— 缺省。所有 provider / connector 走 mock，server env 全空也能跑。
#   staging    —— Supabase 必填；OpenAI / Google Search Console 可空（warn）。
#   production —— Supabase + OpenAI + Google Search Console + NEXT_PUBLIC_SITE_URL 全部必填。
#
# 接入真实模式时：先改 NEXT_PUBLIC_APP_MODE，再用下方模板填齐对应 server env。

# =============================================================================
# ① 模式 + public env（NEXT_PUBLIC_* 客户端可见，可放心嵌入 client bundle）
# =============================================================================

# 必填：app 模式
# demo / staging / production
NEXT_PUBLIC_APP_MODE=demo

# 可选：与 NEXT_PUBLIC_APP_MODE='demo' 等价。Topbar 仍读这个字段显示 "Demo mode" 标识。
NEXT_PUBLIC_DEMO_MODE=true

# staging / production 推荐填：canonical site url（用于 OG 标签、绝对链接、citation 监控）
# demo 模式留空。
NEXT_PUBLIC_SITE_URL=

# =============================================================================
# ② Supabase（server-only，**不要**在 client bundle 引用）
# =============================================================================
# staging 模式：SUPABASE_URL + SUPABASE_ANON_KEY 必填
# production 模式：三个全必填（service role 用于服务端写操作）
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# ③ OpenAI（server-only）
# =============================================================================
# staging 模式：选填（未配走 mock，warn）
# production 模式：必填
OPENAI_API_KEY=

# =============================================================================
# ④ Google Search Console（server-only，给 GEO citation 监控用）
# =============================================================================
# staging 模式：选填（未配走 mock，warn）
# production 模式：必填
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=

# =============================================================================
# ⑤ 预留（server-only，目前 demo 阶段未启用）
# =============================================================================
GITHUB_TOKEN=
MCP_SERVERS=

# Cognitive Venture OS — 环境变量示例
#
# 复制为 .env.local 并填入实际值。
# MVP / Demo 阶段：DEMO_MODE 留 true，env key 全空也能跑。
# 接入真实 provider 时：把 DEMO_MODE 设为 false，并补齐对应 env key。

# ---------- Demo 模式开关 ----------
# true（缺省）→ 所有 provider / connector 走 mock，env key 全部可空。
# false       → 真实模式，env key 必填，provider 工厂会切到真实 SDK。
# Vercel 部署时在 Project Settings → Environment Variables 显式设为 'true'。
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# ---------- Supabase (预留, Demo 未启用) ----------
# Public anon key，客户端可见。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------- OpenAI (预留, Demo 未启用) ----------
# Server-only key，访问 LLM 用。
OPENAI_API_KEY=

# ---------- GitHub (预留, Demo 未启用) ----------
# Personal access token，访问 GitHub API 用。
GITHUB_TOKEN=

# ---------- MCP (预留, Demo 未启用) ----------
# 逗号分隔的 MCP server 列表，例如 "stdio:foo,http:bar"。
MCP_SERVERS=
